# Some packages we depend on (notably better-auth) declare peerOptional
# dependencies on framework integrations we don't use (SvelteKit, Next.js,
# etc.). When those peers transitively pin a different version of vite or
# similar than the one we use, npm 7+ refuses the install. Setting
# legacy-peer-deps here mirrors npm 6's permissive behavior for peer
# resolution, which is appropriate when the conflicting peer is for
# functionality we genuinely don't use.
#
# Documented project-wide decision (2026-04-26) rather than a per-command
# flag, so npm install behaves the same for every contributor.
legacy-peer-deps=true
