# PJS3 API environment variables
#
# Copy to .env and adjust as needed. .env is gitignored.
# All variables are optional; defaults are shown.

# Port the API listens on. Default: 8443.
# PORT=8443

# Bind address. Default: 0.0.0.0 (all interfaces).
# Set to 127.0.0.1 to restrict to loopback.
# HOST=0.0.0.0

# DATABASE_URL -- connection string for the production database, used by
# the database_reachable check on /checkSetup. Format:
#   mysql://user:password@host:port/dbname
# DATABASE_URL=

# Test database credentials (only needed if you run DB-touching tests).
# Two users are required, both with grants on `pjs3\_test\_%`.* :
#   - bootstrap: CREATE, DROP -- used to spin up + tear down per-test DBs
#   - worker:    ALL          -- used for migrations and queries inside the per-test DB
# See docs/adr/0001-database-setup-and-test-isolation.md for full setup.
# Trailing slash, no DB name; the per-test DB is appended at runtime.
# TEST_BOOTSTRAP_DATABASE_URL=mysql://pjs3_test_bootstrap:password@host:3306/
# TEST_DATABASE_URL_BASE=mysql://pjs3_test:password@host:3306/
